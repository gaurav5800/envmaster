{
  "name": "envmaster",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "bin": {
    "envmaster": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "start": "node dist/index.js",
     
    "test": "vitest run",
  "test:watch": "vitest",
   "check": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaurav5800/envmaster.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gaurav5800/envmaster/issues"
  },
  "homepage": "https://github.com/gaurav5800/envmaster#readme",
  "description": "A modern CLI to validate, generate and manage .env files.",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.6",
    "ora": "^9.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^9.39.4",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
